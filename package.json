{
  "name": "pyrite-workspace",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/generator",
    "packages/TIE",
    "packages/XW",
    "packages/XvT",
    "packages/BoP",
    "packages/XWA",
    "packages/components"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspace @pickledyoda/pyrite",
    "test": "npm run test --workspace @pickledyoda/pyrite -- --spec --e2e=false",
    "gencode": "npm run gencode --workspace @pickledyoda/pyrite-generator"
  }
}
